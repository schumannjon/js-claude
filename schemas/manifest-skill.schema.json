{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "manifest-skill",
  "title": "Skill Manifest",
  "description": "Manifest for a Claude Code skill (.md file used as a slash command)",
  "type": "object",
  "required": ["id", "name", "type", "version", "description", "author", "tags", "files", "install"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Kebab-case unique identifier. Must match the directory name."
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name."
    },
    "type": {
      "type": "string",
      "const": "skill"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version string."
    },
    "description": {
      "type": "string",
      "description": "One to three sentences describing what the skill does."
    },
    "author": {
      "type": "string",
      "description": "GitHub username or display name."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "minItems": 1,
      "description": "Lowercase tags for discovery."
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Filenames present in this item's directory."
    },
    "install": {
      "type": "object",
      "required": ["instructions"],
      "additionalProperties": false,
      "properties": {
        "destination": {
          "type": "string",
          "description": "Target path for installation (e.g. ~/.claude/skills/)."
        },
        "instructions": {
          "type": "string",
          "description": "Human-readable installation instructions."
        }
      }
    }
  }
}
