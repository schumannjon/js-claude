{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "manifest-agent",
  "title": "Agent Manifest",
  "description": "Manifest for a custom Claude Code subagent definition",
  "type": "object",
  "required": ["id", "name", "type", "version", "description", "author", "tags", "files", "install"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "agent"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "minItems": 1
    },
    "model": {
      "type": "string",
      "description": "Preferred model ID (e.g. claude-sonnet-4-6). Omit to use default."
    },
    "tools_required": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Claude Code built-in tools the agent depends on."
    },
    "input_schema": {
      "type": "object",
      "description": "JSON Schema describing the arguments the agent expects."
    },
    "output_format": {
      "type": "string",
      "description": "Description of what the agent returns."
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "install": {
      "type": "object",
      "required": ["instructions"],
      "additionalProperties": false,
      "properties": {
        "destination": {
          "type": "string"
        },
        "instructions": {
          "type": "string"
        }
      }
    }
  }
}
