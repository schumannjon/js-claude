{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "manifest-prompt",
  "title": "Prompt Manifest",
  "description": "Manifest for a reusable prompt template",
  "type": "object",
  "required": ["id", "name", "type", "version", "description", "author", "tags", "files", "install"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "prompt"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "minItems": 1
    },
    "parameters": {
      "type": "array",
      "description": "Template parameters the prompt accepts.",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "required": { "type": "boolean", "default": false },
          "default": { "type": "string" },
          "description": { "type": "string" },
          "enum": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "context_needed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "What the user should provide before using this prompt (e.g. file path, language)."
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "install": {
      "type": "object",
      "required": ["instructions"],
      "additionalProperties": false,
      "properties": {
        "instructions": {
          "type": "string"
        }
      }
    }
  }
}
