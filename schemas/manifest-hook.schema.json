{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "manifest-hook",
  "title": "Hook Manifest",
  "description": "Manifest for a Claude Code lifecycle hook (shell script + settings snippet)",
  "type": "object",
  "required": ["id", "name", "type", "version", "description", "author", "tags", "event", "files", "install"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Kebab-case unique identifier. Must match the directory name."
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name."
    },
    "type": {
      "type": "string",
      "const": "hook"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "minItems": 1
    },
    "event": {
      "type": "string",
      "enum": ["PreToolUse", "PostToolUse", "Stop", "Notification", "SubagentStop"],
      "description": "Claude Code lifecycle event that triggers this hook."
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "For PreToolUse/PostToolUse: which tool names trigger this hook. Omit to match all tools."
    },
    "matcher": {
      "type": "string",
      "description": "Optional regex matched against the tool input JSON for selective firing."
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Must include the shell script and settings-snippet.json."
    },
    "install": {
      "type": "object",
      "required": ["instructions"],
      "additionalProperties": false,
      "properties": {
        "destination": {
          "type": "string"
        },
        "instructions": {
          "type": "string"
        }
      }
    }
  }
}
