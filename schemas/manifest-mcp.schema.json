{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "manifest-mcp",
  "title": "MCP Server Manifest",
  "description": "Manifest for an MCP (Model Context Protocol) server configuration",
  "type": "object",
  "required": ["id", "name", "type", "version", "description", "author", "tags", "command", "files", "install"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "const": "mcp"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "minItems": 1
    },
    "command": {
      "type": "string",
      "description": "Executable to run the MCP server (e.g. npx, node, python, uvx)."
    },
    "args": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Arguments passed to the command."
    },
    "env_required": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Environment variables the server requires."
    },
    "env_optional": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional environment variables."
    },
    "scope": {
      "type": "string",
      "enum": ["user", "project"],
      "default": "user",
      "description": "Where to install: user-level or project-level settings."
    },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Must include settings-snippet.json."
    },
    "install": {
      "type": "object",
      "required": ["instructions"],
      "additionalProperties": false,
      "properties": {
        "instructions": {
          "type": "string"
        }
      }
    }
  }
}
